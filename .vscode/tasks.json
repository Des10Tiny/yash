{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake_configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B",
                "build",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
            ],
            "group": "build"
        },
        {
            "label": "cmake_build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "cmake_configure",
            "presentation": {
                "reveal": "silent"
            }
        }
    ]
}